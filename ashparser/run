#!/usr/bin/env bash
set -euo pipefail
PROJ="$(cd "$(dirname "$0")" && pwd)"
export PATH="$HOME/.local/bin:$PATH"

BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[0;36m'; GREEN='\033[0;32m'; RED='\033[0;31m'; NC='\033[0m'

_heal_env() {
    local cfg="$PROJ/.pixi/envs/default/share/max/modular.cfg"
    [ -f "$cfg" ] || return 0
    local rec; rec=$(grep "^package_root" "$cfg" | head -1 | sed 's|.*= ||; s|/.pixi/.*||')
    [ "$rec" = "$PROJ" ] && return 0; [ -n "$rec" ] || return 0
    sed -i "s|${rec}/|${PROJ}/|g" "$cfg"
    printf "${DIM}[env healed → %s]${NC}\n" "$(basename "$PROJ")" >&2
}
_heal_env

mj() {
    local _e _o _rc=0; _e=$(mktemp)
    _o=$( (cd "$PROJ" && magic run mojo run -I . "$@") 2>"$_e" ) || _rc=$?
    [ "$_rc" -eq 0 ] || { cat "$_e" >&2; rm -f "$_e"; return "$_rc"; }
    rm -f "$_e"; printf '%s\n' "$_o"
}

printf "\n${BOLD}${CYAN}▶  ashparser — tests${NC}\n\n"

out=$(mj tests/test_parser.mojo)

echo "$out" | grep -E "^  (PASS|FAIL)|^──|^All"

pass=$(echo "$out" | grep -c "^  PASS" || true)
fail=$(echo "$out" | grep -c "^  FAIL" || true)

printf "\n"
if [ "$fail" -eq 0 ]; then
    printf "${GREEN}${BOLD}✓  $pass passed, 0 failed.${NC}\n\n"
else
    printf "${RED}${BOLD}✗  $fail failed (of $((pass + fail))).${NC}\n\n"
    exit 1
fi
